{
  "name": "morphql-monorepo",
  "version": "0.1.36",
  "private": true,
  "description": "MorphQL Monorepo - A high-performance Query-to-Code engine",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @morphql/core",
    "build:all": "npm run build --workspaces --if-present",
    "dev": "npm run dev -w @morphql/core",
    "test": "npm run test -w @morphql/core",
    "test:all": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "playground": "npm run dev -w @morphql/playground",
    "server": "npm run start:dev -w @morphql/server-instance",
    "n8n": "npm run build -w n8n-nodes-morphql && docker compose -f docker-compose.n8n.yml up --build"
  },
  "keywords": [
    "morphql",
    "transform",
    "json",
    "xml",
    "edifact",
    "edi"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "prettier": "^3.8.1"
  }
}
