{
  "name": "n8n-nodes-morphql",
  "version": "0.1.36",
  "description": "n8n node for MorphQL declarative transformations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/MorphQLTransform.ts src/MorphQLServerCredentials.credentials.ts src/index.ts --format cjs,esm --dts --clean && cp src/morphql.svg dist/",
    "dev": "tsup src/MorphQLTransform.ts src/MorphQLServerCredentials.credentials.ts src/index.ts --format cjs,esm --watch",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run"
  },
  "keywords": [
    "n8n-community-node-package",
    "morphql",
    "transform",
    "Data Transformation"
  ],
  "author": "Hyperwindmill",
  "license": "MIT",
  "dependencies": {
    "@morphql/core": "^0.1.36"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "n8n-workflow": "^1.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/MorphQLServerCredentials.credentials.js"
    ],
    "nodes": [
      "dist/MorphQLTransform.js"
    ]
  }
}
